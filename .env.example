# ── AWS ──────────────────────────────────────────────────────
AWS_REGION=ap-southeast-3
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret

# Bedrock model (must support vision + Converse API)
BEDROCK_MODEL_ID=amazon.nova-pro-v1:0
# Tried in order if the primary model errors (account access flaps)
BEDROCK_FALLBACK_MODELS=apac.amazon.nova-pro-v1:0,amazon.nova-lite-v1:0,anthropic.claude-haiku-4-5-20251001-v1:0

# ── Datadog LLM Observability (agentless) ───────────────────
DD_API_KEY=your-dd-api-key
DD_APP_KEY=your-dd-app-key
DD_SITE=datadoghq.com
DD_LLMOBS_ENABLED=1
DD_LLMOBS_AGENTLESS_ENABLED=1
DD_LLMOBS_ML_APP=your-ml-app-name
